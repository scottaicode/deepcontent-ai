{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "github": {
    "silent": true
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/create", "dest": "/create.html" },
    { "src": "/(.*)", "dest": "/$1.html" }
  ]
}
